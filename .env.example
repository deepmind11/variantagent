# LLM Configuration (choose one)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Default LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Default model (provider-specific)
LLM_MODEL=claude-sonnet-4-20250514

# NCBI E-utilities (optional but recommended — increases rate limit from 3/sec to 10/sec)
NCBI_API_KEY=
NCBI_EMAIL=your-email@example.com

# LangSmith Observability (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=variantagent
LANGSMITH_TRACING_V2=true

# Human-in-the-loop confidence threshold (0.0 - 1.0)
# Classifications with confidence below this threshold pause for human review
HITL_CONFIDENCE_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO
